    <IncludeFile Include="deploy/questing/ar/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ar/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
