    <IncludeFile Include="deploy/questing/fr/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/fr/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/fr/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/fr/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/es/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/es/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/es/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/es/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/es/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/es/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/ru/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/ru/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/ru/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ru/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/ru/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ru/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/it/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/it/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/it/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/it/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/it/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/it/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

