<Project Sdk="Aiursoft.Apkg.Sdk">
  <PropertyGroup>
    <PackageName>anduinos-gnome-shell-locale</PackageName>
    <PackageVersion>2.0.0~beta2-1+$(SuiteShortName)</PackageVersion>
    <Maintainer>AnduinOS Team &lt;anduin@aiursoft.com&gt;</Maintainer>
    <PackageDescription>AnduinOS GNOME Shell locale overrides — renames Pin to Dash/Dock → Taskbar</PackageDescription>
    <Section>admin</Section>
    <PackageHomepage>https://www.anduinos.com</PackageHomepage>
    <RepositoryUrl>https://github.com/AiursoftWeb/AnduinOS-Packages</RepositoryUrl>
    <LicenseType>GPL-3.0</LicenseType>
    <TargetDistro>anduinos</TargetDistro>
    <TargetSuites>noble-addon questing-addon resolute-addon</TargetSuites>
    <TargetArchitectures>all</TargetArchitectures>
    <Component>main</Component>
    <SuiteShortNameMap>noble-addon=noble questing-addon=questing resolute-addon=resolute</SuiteShortNameMap>
  </PropertyGroup>

  <ItemGroup>
    <PrebuildCommand Run="bash download.sh" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Per-language GNOME Shell locale overrides.
      /usr/share/locale/ has higher gettext priority than
      /usr/share/locale-langpack/, so our patched .mo files
      take precedence without conflicting any Ubuntu package.
    -->
    <IncludeFile Include="deploy/noble/en/LC_MESSAGES/gnome-shell.mo"     Target="/usr/share/locale/en/LC_MESSAGES/gnome-shell.mo"     Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/en/LC_MESSAGES/gnome-shell.mo"  Target="/usr/share/locale/en/LC_MESSAGES/gnome-shell.mo"     Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/en/LC_MESSAGES/gnome-shell.mo"  Target="/usr/share/locale/en/LC_MESSAGES/gnome-shell.mo"     Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/zh_CN/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/zh_CN/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/zh_CN/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/zh_CN/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/zh_CN/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/zh_CN/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/zh_TW/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/zh_TW/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/zh_TW/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/zh_TW/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/zh_TW/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/zh_TW/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/ja/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/ja/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/ja/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ja/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/ja/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ja/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/ko/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/ko/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/ko/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ko/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/ko/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/ko/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/vi/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/vi/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/vi/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/vi/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/vi/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/vi/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/th/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/th/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/th/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/th/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/th/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/th/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/de/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/de/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/de/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/de/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/de/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/de/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

