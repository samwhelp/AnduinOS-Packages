    <IncludeFile Include="deploy/questing/pt_BR/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/pt_BR/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/pt_BR/LC_MESSAGES/gnome-shell.mo" Target="/usr/share/locale/pt_BR/LC_MESSAGES/gnome-shell.mo"   Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/nl/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/nl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/nl/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/nl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/nl/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/nl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/sv/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/sv/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/sv/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/sv/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/sv/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/sv/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/pl/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/pl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/pl/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/pl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/pl/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/pl/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

    <IncludeFile Include="deploy/noble/tr/LC_MESSAGES/gnome-shell.mo"      Target="/usr/share/locale/tr/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFile Include="deploy/questing/tr/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/tr/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFile Include="deploy/resolute/tr/LC_MESSAGES/gnome-shell.mo"   Target="/usr/share/locale/tr/LC_MESSAGES/gnome-shell.mo"      Condition="'$(Suite)' == 'resolute-addon'" />

