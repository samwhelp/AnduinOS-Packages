<Project Sdk="Aiursoft.Apkg.Sdk">
  <PropertyGroup>
    <PackageName>anduinos-session</PackageName>
    <PackageVersion>1.0.2</PackageVersion>
    <Maintainer>AnduinOS Team &lt;anduin@aiursoft.com&gt;</Maintainer>
    <PackageDescription>AnduinOS session configuration and login entry</PackageDescription>
    <Section>gnome</Section>
    <PackageHomepage>https://www.anduinos.com</PackageHomepage>
    <LicenseType>GPL-3.0</LicenseType>
    
    <Provides>ubuntu-session</Provides>
    <Conflicts>ubuntu-session</Conflicts>
    <Replaces>ubuntu-session</Replaces>
    
    <TargetDistro>anduinos</TargetDistro>
    <TargetSuites>noble-addon questing-addon resolute-addon</TargetSuites>
    <TargetArchitectures>all</TargetArchitectures>
    <Component>main</Component>
  </PropertyGroup>

  <ItemGroup>
    <Dependency Include="gnome-session" />
    <Dependency Include="gnome-shell" />
    <Dependency Include="anduinos-mimeapps" />
  </ItemGroup>

  <ItemGroup>
    <IncludeFile Include="assets/anduinos.desktop" Target="/usr/share/wayland-sessions/anduinos.desktop" />
    <IncludeFile Include="assets/anduinos.session" Target="/usr/share/gnome-session/sessions/anduinos.session" />
  </ItemGroup>
  
  <ItemGroup>
    <PostInstallScript Include="scripts/postinst.sh" />
  </ItemGroup>
</Project>
