WIDGETS = {
    'weather': ('Show Weather', 'simple-weather@romanlefler.com'),
    'network': ('Show Network', 'network-stats@gnome.noroadsleft.xyz'),
}


class PanelWidgetsPage(Gtk.Box):
    def __init__(self, win):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.set_margin_top(20)
        self.set_margin_bottom(20)
        self.set_margin_start(24)
        self.set_margin_end(24)

        t = Gtk.Label()
        t.set_markup('<b>Panel Widgets</b>')
        t.set_halign(Gtk.Align.START)
        self.append(t)

        sub = Gtk.Label(label='Toggle panel indicator widgets on or off.')
        sub.set_halign(Gtk.Align.START)
        sub.add_css_class('dim-label')
        self.append(sub)

        for key, (label, uuid) in WIDGETS.items():
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.set_margin_top(8)

            lbl = Gtk.Label(label=label)
            lbl.set_halign(Gtk.Align.START)
            lbl.set_hexpand(True)
            row.append(lbl)

            switch = Gtk.Switch()
            switch.set_active(_ext_is_enabled(uuid))
            switch.connect('state-set', self._on_toggle, uuid, label)
            switch.set_valign(Gtk.Align.CENTER)
            row.append(switch)

            self.append(row)

    def _on_toggle(self, switch, state, uuid, label):
        action = 'enable' if state else 'disable'
        try:
            subprocess.run(['gnome-extensions', action, uuid], check=True)
            self.win.status.set_label(f'✓ {label} — {action}d')
        except subprocess.CalledProcessError:
            self.win.status.set_label(f'✗ Failed to {action} {label}')
            # revert switch
            switch.handler_block_by_func(self._on_toggle)
            switch.set_active(not state)
            switch.handler_unblock_by_func(self._on_toggle)


