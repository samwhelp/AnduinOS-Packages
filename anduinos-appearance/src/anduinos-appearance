class StylePage(Gtk.Box):
    def __init__(self, win):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.win = win
        self.set_margin_top(20)
        self.set_margin_bottom(20)
        self.set_margin_start(24)
        self.set_margin_end(24)

        t = Gtk.Label()
        t.set_markup('<b>Taskbar Style</b>')
        t.set_halign(Gtk.Align.START)
        self.append(t)

        sub = Gtk.Label(label='Choose the visual style of your taskbar.')
        sub.set_halign(Gtk.Align.START)
        sub.add_css_class('dim-label')
        self.append(sub)

        # preview
        card = Gtk.Frame()
        card.add_css_class('card')
        card.set_size_request(340, 110)
        self.preview = Gtk.DrawingArea()
        self.preview.set_size_request(340, 110)
        self.preview.set_draw_func(self._draw, win.current_style, win.current_position)
        card.set_child(self.preview)
        self.append(card)

        # buttons
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        self.btn11 = Gtk.Button(label='  11  ')
        self.btn11.connect('clicked', self._on_click, 'eleven')
        self.btn10 = Gtk.Button(label='  Classic  ')
        self.btn10.connect('clicked', self._on_click, 'classic')
        box.append(self.btn11)
        box.append(self.btn10)
        self.append(box)

        self._highlight_btn()

    def _draw(self, area, cr, w, h, style, position):
        draw_preview(area, cr, w, h, style, position)

    def _on_click(self, btn, style):
        if apply_style_and_position(style, self.win.current_position):
            self.win.current_style = style
            self.win._sync_all_highlights()
            self.win._refresh_previews()
            self.win.status.set_label(f'✓ Applied — {self._label(style)} | {self.win.current_position.title()}')
        else:
            self.win.status.set_label('✗ Failed to apply style')

    def _highlight_btn(self):
        if self.win.current_style == 'eleven':
            self.btn11.add_css_class('suggested-action')
            self.btn10.remove_css_class('suggested-action')
        else:
            self.btn10.add_css_class('suggested-action')
            self.btn11.remove_css_class('suggested-action')

    @staticmethod
    def _label(s):
        return 'Windows 11' if s == 'eleven' else 'Classic'


# ── position page ────────────────────────────────────────────────

POS_LABELS = {'bottom': 'Bottom', 'top': 'Top', 'left': 'Left', 'right': 'Right'}


class PositionPage(Gtk.Box):
    def __init__(self, win):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.win = win
        self.set_margin_top(20)
        self.set_margin_bottom(20)
        self.set_margin_start(24)
        self.set_margin_end(24)

        t = Gtk.Label()
        t.set_markup('<b>Taskbar Position</b>')
        t.set_halign(Gtk.Align.START)
        self.append(t)

        sub = Gtk.Label(label='Choose where your taskbar sits on screen.')
        sub.set_halign(Gtk.Align.START)
        sub.add_css_class('dim-label')
        self.append(sub)

        # preview
        card = Gtk.Frame()
        card.add_css_class('card')
        card.set_size_request(340, 130)
        self.preview = Gtk.DrawingArea()
        self.preview.set_size_request(340, 130)
        self.preview.set_draw_func(self._draw, win.current_style, win.current_position)
        card.set_child(self.preview)
        self.append(card)

        # position grid: 2×2  (top, bottom) / (left, right)
        grid = Gtk.Grid()
        grid.set_row_spacing(8)
        grid.set_column_spacing(8)
        grid.set_halign(Gtk.Align.CENTER)

        positions = [('bottom', 0, 1), ('top', 0, 0), ('left', 1, 0), ('right', 1, 1)]
        self.pos_btns = {}
        for pos, row, col in positions:
            btn = Gtk.ToggleButton(label=f'  {POS_LABELS[pos]}  ')
            btn.connect('toggled', self._on_pos_toggled, pos)
            grid.attach(btn, col, row, 1, 1)
            self.pos_btns[pos] = btn

        self.append(grid)

        self._highlight_pos()

    def _draw(self, area, cr, w, h, style, position):
        draw_preview(area, cr, w, h, style, position)

    def _on_pos_toggled(self, btn, pos):
        if not btn.get_active():
            # Prevent deselecting the only active position
            if pos == self.win.current_position:
                btn.handler_block_by_func(self._on_pos_toggled)
                btn.set_active(True)
                btn.handler_unblock_by_func(self._on_pos_toggled)
            return
        # radio behaviour: unset all other position buttons
        for p, other in self.pos_btns.items():
            if p != pos:
                other.handler_block_by_func(self._on_pos_toggled)
                other.set_active(False)
                other.handler_unblock_by_func(self._on_pos_toggled)
        if apply_style_and_position(self.win.current_style, pos):
            self.win.current_position = pos
            self.win._refresh_previews()
            self.win.status.set_label(f'✓ Applied — {StylePage._label(self.win.current_style)} | {POS_LABELS[pos]}')
        else:
            self.win.status.set_label('✗ Failed to apply position')

    def _highlight_pos(self):
        for p, btn in self.pos_btns.items():
            if p == self.win.current_position:
                btn.handler_block_by_func(self._on_pos_toggled)
                btn.set_active(True)
                btn.handler_unblock_by_func(self._on_pos_toggled)


