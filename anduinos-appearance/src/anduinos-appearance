        btn_reset.add_css_class('destructive-action')
        btn_reset.connect('clicked', self._on_reset)
        self.append(btn_reset)

    def _on_reset(self, btn):
        # first confirmation
        dlg1 = Gtk.MessageDialog(
            transient_for=self.win,
            modal=True,
            message_type=Gtk.MessageType.WARNING,
            buttons=Gtk.ButtonsType.NONE,
        )
        dlg1.set_markup('<b>Reset desktop settings?</b>')
        dlg1.set_secondary_text('This will reset all GNOME Shell settings to factory defaults.\nYour extensions, panel layout, and preferences will be lost.')
        dlg1.add_button('Cancel', Gtk.ResponseType.CANCEL)
        btn_reset1 = dlg1.add_button('Reset', Gtk.ResponseType.OK)
        btn_reset1.add_css_class('destructive-action')
        dlg1.set_default_response(Gtk.ResponseType.CANCEL)
        dlg1.present()

        def on_response1(dlg, resp):
            dlg.destroy()
            if resp != Gtk.ResponseType.OK:
                return
            # second confirmation
            dlg2 = Gtk.MessageDialog(
                transient_for=self.win,
                modal=True,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.NONE,
            )
            dlg2.set_markup('<b>Are you absolutely sure?</b>')
            dlg2.set_secondary_text('This action cannot be undone.\nA Shell restart may be required afterwards.')
            dlg2.add_button('Cancel', Gtk.ResponseType.CANCEL)
            btn_reset2 = dlg2.add_button('Reset Everything', Gtk.ResponseType.OK)
            btn_reset2.add_css_class('destructive-action')
            dlg2.set_default_response(Gtk.ResponseType.CANCEL)
            dlg2.present()

            def on_response2(dlg, resp):
                dlg.destroy()
                if resp != Gtk.ResponseType.OK:
                    return
                try:
                    subprocess.run(['dconf', 'reset', '-f', '/org/gnome/shell/'], check=True)
                    self.win.status.set_label('✓ Desktop settings reset. Restart Shell to apply.')
                except subprocess.CalledProcessError:
                    self.win.status.set_label('✗ Failed to reset')

            dlg2.connect('response', on_response2)

        dlg1.connect('response', on_response1)


