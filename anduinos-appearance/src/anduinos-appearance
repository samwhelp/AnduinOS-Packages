class AppearanceWindow(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title='AnduinOS Appearance')
        self.set_default_size(600, 420)

        self.current_style, self.current_position = detect_current()

        # header
        header = Gtk.HeaderBar()
        self.set_titlebar(header)

        # ── horizontal split: sidebar | content ──
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.set_child(hbox)

        # -- sidebar --
        sidebar = Gtk.ListBox()
        sidebar.set_size_request(160, -1)
        sidebar.add_css_class('navigation-sidebar')

        items = ['Taskbar Style', 'Taskbar Position', 'Panel Widgets', 'Advanced']
        for i, name in enumerate(items):
            row = Gtk.ListBoxRow()
            label = Gtk.Label(label=name)
            label.set_xalign(0)
            label.set_margin_start(12)
            label.set_margin_top(10)
            label.set_margin_bottom(10)
            row.set_child(label)
            sidebar.append(row)

        sidebar.connect('row_selected', self._on_sidebar_select)
        hbox.append(sidebar)

        # -- separator --
        sep = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        hbox.append(sep)

        # -- stack --
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)

        self.style_page = StylePage(self)
        self.position_page = PositionPage(self)
        self.widgets_page = PanelWidgetsPage(self)
        self.advanced_page = AdvancedPage(self)

        self.stack.add_titled(self.style_page, 'style', 'Taskbar Style')
        self.stack.add_titled(self.position_page, 'position', 'Taskbar Position')
        self.stack.add_titled(self.widgets_page, 'widgets', 'Panel Widgets')
        self.stack.add_titled(self.advanced_page, 'advanced', 'Advanced')

        # -- right side: stack + status --
        vbox_right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        vbox_right.append(self.stack)

        self.status = Gtk.Label()
        self.status.set_halign(Gtk.Align.START)
        self.status.add_css_class('dim-label')
        self.status.set_margin_start(12)
        self.status.set_margin_bottom(8)
        self.status.set_margin_top(4)
        vbox_right.append(self.status)

        hbox.append(vbox_right)

        # select first sidebar item AFTER everything is built
        sidebar.select_row(sidebar.get_row_at_index(0))

    def _on_sidebar_select(self, listbox, row):
        if row is None or not hasattr(self, 'stack'):
            return
        idx = row.get_index()
        page_names = {0: 'style', 1: 'position', 2: 'widgets', 3: 'advanced'}
        self.stack.set_visible_child_name(page_names.get(idx, 'style'))

    def _sync_all_highlights(self):
        self.style_page._highlight_btn()

    def _refresh_previews(self):
        for page in [self.style_page, self.position_page]:
            page.preview.set_draw_func(page._draw, self.current_style, self.current_position)
            page.preview.queue_draw()


class AppearanceApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='com.anduinos.Appearance')

    def do_activate(self):
        win = AppearanceWindow(self)
        win.present()


def main():
    return AppearanceApp().run(None)


if __name__ == '__main__':
    raise SystemExit(main())
