#!/bin/bash
set -e
set -u

# Only fire on session open (not close)
[ "${PAM_TYPE:-}" = "open_session" ] || exit 0

# Only for real users, not root or system accounts
[ -n "${PAM_USER:-}" ] || exit 0
[ "$PAM_USER" != "root" ] || exit 0
uid=$(id -u "$PAM_USER" 2>/dev/null) || exit 0
[ "$uid" -ge 1000 ] || exit 0

# Check caller has a desktop D-Bus session
bus="/run/user/$uid/bus"
[ -S "$bus" ] || exit 0

# Debounce: skip if we fired within the last 5 seconds
stamp="/tmp/.sudo-notify-$uid"
now=$(date +%s)
if [ -f "$stamp" ]; then
    last=$(cat "$stamp" 2>/dev/null || echo 0)
    [ "$((now - last))" -lt 5 ] && exit 0
fi
echo "$now" > "$stamp"

# Fire notification (fire-and-forget, never block sudo)
DBUS_SESSION_BUS_ADDRESS="unix:path=$bus" \
    notify-send "Sudo Request" "User: $PAM_USER" \
    -i dialog-password -t 5000 2>/dev/null &
disown
