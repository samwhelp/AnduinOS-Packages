<Project Sdk="Aiursoft.Apkg.Sdk">
  <PropertyGroup>
    <PackageName>anduinos-gnome-extensions</PackageName>
    <PackageVersion>1.0.12</PackageVersion>
    <Maintainer>AnduinOS Team &lt;anduin@aiursoft.com&gt;</Maintainer>
    <PackageDescription>Meta-package that installs all AnduinOS GNOME Shell extensions. Installing this package pulls in the complete set of extensions used by AnduinOS desktop. Individual extensions can be removed separately.</PackageDescription>
    <Section>metapackages</Section>
    <PackageHomepage>https://anduinos.com</PackageHomepage>
    <LicenseType>GPL-2.0</LicenseType>
    <TargetDistro>anduinos</TargetDistro>
    <TargetSuites>noble-addon questing-addon resolute-addon</TargetSuites>
    <TargetArchitectures>all</TargetArchitectures>
    <Component>main</Component>
    <!-- Replace Ubuntu's gnome-shell-ubuntu-extensions meta-package -->
    <Provides>gnome-shell-ubuntu-extensions</Provides>
    <Conflicts>gnome-shell-ubuntu-extensions</Conflicts>
    <Replaces>gnome-shell-ubuntu-extensions</Replaces>
  </PropertyGroup>

  <ItemGroup>
    <!-- AnduinOS original extensions: source code lives in AnduinOS repos -->
    <Dependency Include="gnome-shell-extension-anduinos-loc" />
    <Dependency Include="gnome-shell-extension-no-power-icon" />
    <Dependency Include="gnome-shell-extension-noti-bottom-right" />

    <!-- Third-party extensions packaged by AnduinOS (downloaded from GNOME Extensions at build time) -->
    <Dependency Include="gnome-shell-extension-appindicator-anduinos" />
    <Dependency Include="gnome-shell-extension-arcmenu" />
    <Dependency Include="gnome-shell-extension-accent-gtk-theme" />
    <Dependency Include="gnome-shell-extension-accent-icons-theme" />
    <Dependency Include="gnome-shell-extension-accent-user-theme" />
    <Dependency Include="gnome-shell-extension-blur-my-shell" />
    <Dependency Include="gnome-shell-extension-clipboard-indicator" />
    <Dependency Include="gnome-shell-extension-customize-ibus" />
    <Dependency Include="gnome-shell-extension-dash-to-panel-anduinos" />
    <Dependency Include="gnome-shell-extension-desktop-icons-ng-anduinos" />
    <Dependency Include="gnome-shell-extension-lockkeys" />
    <Dependency Include="gnome-shell-extension-mediacontrols" />
    <Dependency Include="gnome-shell-extension-network-stats" />
    <Dependency Include="gnome-shell-extension-no-overview" />
    <Dependency Include="gnome-shell-extension-proxy-switcher" />
    <Dependency Include="gnome-shell-extension-simple-weather" />
    <Dependency Include="gnome-shell-extension-tiling-assistant" />

    <!-- Extensions from Ubuntu upstream repos -->
    <Recommend Include="gnome-shell-extension-drive-menu" />
    <Recommend Include="gnome-shell-extension-user-theme" />

    <!-- Extension for managing installed extensions -->
    <Recommend Include="gnome-shell-extension-prefs" />
  </ItemGroup>
</Project>
