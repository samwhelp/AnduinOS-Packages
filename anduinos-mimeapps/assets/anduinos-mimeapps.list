# Text with GNOME Text Editor
text/plain=org.gnome.TextEditor.desktop;

# Torrent
application/x-bittorrent=transmission-gtk.desktop;
application/x-utorrent=transmission-gtk.desktop;

# Disk Images with GNOME Disk Image Mounter
application/x-cd-image=gnome-disk-image-mounter.desktop;
application/x-raw-disk-image=gnome-disk-image-mounter.desktop;

# Deb with GNOME Software
application/vnd.debian.binary-package=gnome-software.desktop;
